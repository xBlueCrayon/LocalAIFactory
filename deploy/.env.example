# R2-ACC-CAP6: example environment for LocalAIFactory deployment. Copy to ".env" and set real values.
# NEVER commit a real .env (it is git-ignored). No real secrets belong in this example.

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# --- MSSQL (source of truth; required) ---
# Use a STRONG password; this placeholder must be changed before any deployment.
MSSQL_SA_PASSWORD=CHANGE_ME_Strong_P@ssw0rd
ConnectionStrings__DefaultConnection=Server=mssql,1433;Database=LocalAIFactory;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True

# --- Qdrant (optional vector store; the app degrades gracefully if absent) ---
Qdrant__Enabled=false
Qdrant__Url=http://qdrant:6333

# --- Ollama (optional local models; GPU compose only) ---
Ollama__Enabled=false
Ollama__BaseUrl=http://ollama:11434

# --- Knowledge pack path (optional override; defaults to the bundled pack) ---
# KnowledgePacks__BaseV1Path=/app/knowledge-packs/professional-base-v1
