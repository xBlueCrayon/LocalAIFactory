@model List<LafErp.Core.AuditEvent>
@{ ViewData["Title"] = "Audit Log"; }
<table data-testid="audit-table">
    <thead><tr><th>When (UTC)</th><th>Entity</th><th>Id</th><th>Action</th><th>By</th><th>Details</th></tr></thead>
    <tbody>
    @foreach (var a in Model)
    {
        <tr><td>@a.EventUtc.ToString("yyyy-MM-dd HH:mm:ss")</td><td>@a.EntityType</td><td>@a.EntityId</td><td>@a.Action</td><td>@a.PerformedBy</td><td>@a.Details</td></tr>
    }
    </tbody>
</table>
