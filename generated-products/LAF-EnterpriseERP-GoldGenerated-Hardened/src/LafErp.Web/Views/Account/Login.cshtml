@{ ViewData["Title"] = "Sign in"; }
<h3>Sign in</h3>
<p style="font-size:14px;color:#6b7280">Real PBKDF2-hashed login. Demo users: <code>admin</code> / <code>Admin#12345</code>,
<code>alice</code> / <code>Alice#12345</code>, <code>bob</code> / <code>Bob#12345</code>.</p>
@if (ViewBag.Error != null) { <p style="color:#b91c1c" data-testid="login-error">@ViewBag.Error</p> }
<form method="post" action="/Account/Login" data-testid="login-form">
    @Html.AntiForgeryToken()
    <p><label style="display:inline-block;width:110px">Username</label><input name="username" data-testid="username" /></p>
    <p><label style="display:inline-block;width:110px">Password</label><input name="password" type="password" data-testid="password" /></p>
    <button type="submit" data-testid="login-submit">Sign in</button>
</form>
