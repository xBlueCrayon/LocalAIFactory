@using LocalAIFactory.Core.Entities
@using LocalAIFactory.Core.Enums
@model List<UserAccount>
@{
    ViewData["Title"] = "Users";
    var projects = ViewBag.Projects as List<Project> ?? new();
    var access = ViewBag.Access as Dictionary<int, HashSet<int>> ?? new();
}

<h4 class="mb-1"><i class="bi bi-people me-2"></i>Users &amp; Access</h4>
<div class="text-muted small mb-3">Windows-authenticated users. New users are <strong>Viewer with no project access</strong> (deny-by-default) until granted here.</div>

<div class="card">
<div class="table-responsive"><table class="table align-middle mb-0">
    <thead><tr><th>User</th><th>Role</th><th>Enabled</th><th>Project access</th><th></th></tr></thead>
    <tbody>
    @foreach (var u in Model)
    {
        var granted = access.TryGetValue(u.Id, out var set) ? set : new HashSet<int>();
        <tr>
            <td><strong>@u.WindowsIdentity</strong><div class="text-muted small">last seen @u.LastSeenUtc.ToString("yyyy-MM-dd HH:mm")</div></td>
            <td>
                <form asp-action="SetRole" method="post" class="d-flex gap-1">
                    <input type="hidden" name="userId" value="@u.Id" />
                    <select name="role" class="form-select form-select-sm" style="width:auto">
                        @foreach (var r in Enum.GetValues<UserRole>())
                        { <option value="@r" selected="@(u.Role == r)">@r</option> }
                    </select>
                    <button class="btn btn-sm btn-outline-secondary">Set</button>
                </form>
            </td>
            <td>
                <form asp-action="SetEnabled" method="post">
                    <input type="hidden" name="userId" value="@u.Id" />
                    <input type="hidden" name="enabled" value="@((!u.Enabled).ToString().ToLower())" />
                    <button class="btn btn-sm @(u.Enabled ? "btn-outline-success" : "btn-outline-danger")">@(u.Enabled ? "Enabled" : "Disabled")</button>
                </form>
            </td>
            <td style="max-width:380px">
                @foreach (var p in projects)
                {
                    var has = granted.Contains(p.Id);
                    <form asp-action="@(has ? "RevokeAccess" : "GrantAccess")" method="post" class="d-inline">
                        <input type="hidden" name="userId" value="@u.Id" />
                        <input type="hidden" name="projectId" value="@p.Id" />
                        <button class="btn btn-sm @(has ? "btn-success" : "btn-outline-secondary") mb-1" title="@(has ? "Revoke" : "Grant")">
                            @if (has) { <i class="bi bi-check2 me-1"></i> } @p.Name
                        </button>
                    </form>
                }
                @if (u.Role == UserRole.Admin) { <span class="badge text-bg-light">all (admin)</span> }
            </td>
            <td></td>
        </tr>
    }
    </tbody>
</table></div>
</div>
