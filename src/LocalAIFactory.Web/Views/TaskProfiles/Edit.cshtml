@model TaskProfile
@{ ViewData["Title"] = "Edit Task Profile"; var models = (List<ModelConfiguration>)ViewBag.Models; }

<h3 class="mb-3">Edit profile — @Model.TaskType</h3>

<form asp-action="Edit" method="post" class="row g-3" style="max-width:820px">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="col-md-6">
        <label class="form-label">Primary model</label>
        <select name="primaryModelId" class="form-select">
            <option value="">(use default enabled model)</option>
            @foreach (var m in models) { <option value="@m.Id" selected="@(Model.PrimaryModelId == m.Id)">@m.Name</option> }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Temperature</label>
        <input name="temperature" type="number" step="0.05" value="@Model.Temperature" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Max tokens</label>
        <input name="maxTokens" type="number" value="@Model.MaxTokens" class="form-control" />
    </div>

    <div class="col-md-6 border-top pt-2">
        <div class="form-check"><input class="form-check-input" type="checkbox" name="validationEnabled" value="true" checked="@Model.ValidationEnabled" /><label class="form-check-label">Enable validation</label></div>
        <select name="validationModelId" class="form-select mt-1">
            <option value="">(none)</option>
            @foreach (var m in models) { <option value="@m.Id" selected="@(Model.ValidationModelId == m.Id)">@m.Name</option> }
        </select>
    </div>
    <div class="col-md-6 border-top pt-2">
        <div class="form-check"><input class="form-check-input" type="checkbox" name="comparisonEnabled" value="true" checked="@Model.ComparisonEnabled" /><label class="form-check-label">Enable comparison</label></div>
        <select name="comparisonModelId" class="form-select mt-1">
            <option value="">(none)</option>
            @foreach (var m in models) { <option value="@m.Id" selected="@(Model.ComparisonModelId == m.Id)">@m.Name</option> }
        </select>
    </div>

    <div class="col-12 border-top pt-2">
        <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="useProjectMemory" value="true" checked="@Model.UseProjectMemory" /><label class="form-check-label">Project memory</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="useKnowledgeBase" value="true" checked="@Model.UseKnowledgeBase" /><label class="form-check-label">Knowledge base</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="useKnowledgeGraph" value="true" checked="@Model.UseKnowledgeGraph" /><label class="form-check-label">Knowledge graph</label></div>
    </div>
    <div class="col-12">
        <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="localOnly" value="true" checked="@Model.LocalOnly" /><label class="form-check-label">Local only (block cloud)</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="requireApprovalBeforeCloudUse" value="true" checked="@Model.RequireApprovalBeforeCloudUse" /><label class="form-check-label">Require approval before cloud</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="isEnabled" value="true" checked="@Model.IsEnabled" /><label class="form-check-label">Enabled</label></div>
    </div>

    <div class="col-12">
        <button class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
