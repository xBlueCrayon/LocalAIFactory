@model List<TaskProfile>
@{
    ViewData["Title"] = "Task Profiles";
    var models = (Dictionary<int,string>)ViewBag.Models;
    string Name(int? id) => id != null && models.ContainsKey(id.Value) ? models[id.Value] : "—";
}

<h3 class="mb-3">Task profiles</h3>
<p class="small-muted">Each task type routes to a primary model, with optional validation and comparison. The workspace profiles (Code Modification, Build Analysis, Workspace Planning) are disabled until Phase 2.</p>

<table class="table table-sm table-striped align-middle">
    <thead><tr><th>Task</th><th>Primary</th><th>Validation</th><th>Comparison</th><th>RAG</th><th>Local only</th><th>Enabled</th><th></th></tr></thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.TaskType</td>
            <td>@Name(p.PrimaryModelId)</td>
            <td>@(p.ValidationEnabled ? Name(p.ValidationModelId) : "off")</td>
            <td>@(p.ComparisonEnabled ? Name(p.ComparisonModelId) : "off")</td>
            <td class="small">@(p.UseProjectMemory ? "M" : "-")@(p.UseKnowledgeBase ? "K" : "-")@(p.UseKnowledgeGraph ? "G" : "-")</td>
            <td>@(p.LocalOnly ? "Yes" : "No")</td>
            <td>@(p.IsEnabled ? "Yes" : "No")</td>
            <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">Edit</a></td>
        </tr>
    }
    </tbody>
</table>
<div class="small-muted">RAG flags: M = project memory, K = knowledge base, G = knowledge graph.</div>
