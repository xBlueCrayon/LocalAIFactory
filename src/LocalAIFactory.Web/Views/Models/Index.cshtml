@model List<ModelConfiguration>
@{ ViewData["Title"] = "Models"; }

<h3 class="mb-3">Model configurations</h3>
<p class="small-muted">Single-model operation is the baseline: one local model can serve every task. Cloud providers require an API key and explicit consent.</p>

<table class="table table-sm table-striped align-middle">
    <thead><tr><th>Name</th><th>Provider</th><th>Model</th><th>Base URL</th><th>Default</th><th>Enabled</th><th></th></tr></thead>
    <tbody>
    @foreach (var m in Model)
    {
        <tr>
            <td>@m.Name</td><td>@m.Provider</td><td class="mono">@m.ModelName</td><td class="mono small">@m.BaseUrl</td>
            <td>@(m.IsDefault ? "★" : "")</td>
            <td>@(m.IsEnabled ? "Yes" : "No")</td>
            <td class="text-nowrap">
                <form asp-action="TestConnection" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@m.Id" /><button class="btn btn-sm btn-outline-secondary">Test</button></form>
                <form asp-action="SetDefault" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@m.Id" /><button class="btn btn-sm btn-outline-primary">Default</button></form>
                <button class="btn btn-sm btn-outline-dark" data-bs-toggle="collapse" data-bs-target="#edit-@m.Id">Edit</button>
                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this model?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@m.Id" /><button class="btn btn-sm btn-outline-danger">Delete</button></form>
            </td>
        </tr>
        <tr class="collapse" id="edit-@m.Id"><td colspan="7">
            <form asp-action="Update" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@m.Id" />
                <div class="col-md-3"><label class="form-label small">Name</label><input name="name" value="@m.Name" class="form-control form-control-sm" /></div>
                <div class="col-md-2"><label class="form-label small">Provider</label>
                    <select name="provider" class="form-select form-select-sm">
                        @foreach (var pv in Enum.GetNames(typeof(ModelProvider)))
                        { <option value="@pv" selected="@(m.Provider.ToString() == pv)">@pv</option> }
                    </select>
                </div>
                <div class="col-md-3"><label class="form-label small">Model name</label><input name="modelName" value="@m.ModelName" class="form-control form-control-sm" /></div>
                <div class="col-md-4"><label class="form-label small">Base URL</label><input name="baseUrl" value="@m.BaseUrl" class="form-control form-control-sm" /></div>
                <div class="col-md-3"><label class="form-label small">API key (leave blank to keep)</label><input name="apiKey" type="password" class="form-control form-control-sm" /></div>
                <div class="col-md-3"><label class="form-label small">Embedding model</label><input name="embeddingModel" value="@m.EmbeddingModel" class="form-control form-control-sm" /></div>
                <div class="col-md-2"><label class="form-label small">Temperature</label><input name="temperature" type="number" step="0.05" value="@m.Temperature" class="form-control form-control-sm" /></div>
                <div class="col-md-2"><label class="form-label small">Max tokens</label><input name="maxTokens" type="number" value="@m.MaxTokens" class="form-control form-control-sm" /></div>
                <div class="col-md-2"><label class="form-label small">Context hint</label><input name="contextWindowHint" type="number" value="@m.ContextWindowHint" class="form-control form-control-sm" /></div>
                <div class="col-md-2 form-check mt-4 ms-2"><input class="form-check-input" type="checkbox" name="isEnabled" value="true" checked="@m.IsEnabled" /><label class="form-check-label small">Enabled</label></div>
                <div class="col-12"><button class="btn btn-sm btn-primary">Save</button></div>
            </form>
        </td></tr>
    }
    </tbody>
</table>

<div class="card mt-3"><div class="card-body">
    <h6>Add a model</h6>
    <form asp-action="Create" method="post" class="row g-2">
        @Html.AntiForgeryToken()
        <div class="col-md-3"><label class="form-label small">Name</label><input name="name" class="form-control form-control-sm" required /></div>
        <div class="col-md-2"><label class="form-label small">Provider</label>
            <select name="provider" class="form-select form-select-sm">
                @foreach (var pv in Enum.GetNames(typeof(ModelProvider))) { <option value="@pv">@pv</option> }
            </select>
        </div>
        <div class="col-md-3"><label class="form-label small">Model name</label><input name="modelName" class="form-control form-control-sm" placeholder="qwen2.5-coder:14b" required /></div>
        <div class="col-md-4"><label class="form-label small">Base URL</label><input name="baseUrl" class="form-control form-control-sm" value="http://localhost:11434" required /></div>
        <div class="col-md-3"><label class="form-label small">API key (cloud only)</label><input name="apiKey" type="password" class="form-control form-control-sm" /></div>
        <div class="col-md-3"><label class="form-label small">Embedding model</label><input name="embeddingModel" class="form-control form-control-sm" placeholder="nomic-embed-text" /></div>
        <div class="col-md-2"><label class="form-label small">Temperature</label><input name="temperature" type="number" step="0.05" value="0.2" class="form-control form-control-sm" /></div>
        <div class="col-md-2"><label class="form-label small">Max tokens</label><input name="maxTokens" type="number" value="2048" class="form-control form-control-sm" /></div>
        <div class="col-md-2"><label class="form-label small">Context hint</label><input name="contextWindowHint" type="number" value="8192" class="form-control form-control-sm" /></div>
        <div class="col-12"><button class="btn btn-sm btn-primary">Add model</button></div>
    </form>
</div></div>
