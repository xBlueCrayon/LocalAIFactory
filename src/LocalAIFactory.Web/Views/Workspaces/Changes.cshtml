@{
    ViewData["Title"] = "Changes";
    var workspaces = (IReadOnlyList<Workspace>)ViewBag.Workspaces;
    var changes = (IReadOnlyList<WorkspaceChange>)ViewBag.Changes;
    int? wid = ViewBag.WorkspaceId as int?;
}

<h3 class="mb-1">Changes</h3>
<p class="small-muted">Proposed file changes with reason, prompt and model — the debugging history. In Phase 1 changes are recorded only; applying to disk is a Phase 2 capability.</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <select name="workspaceId" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">All workspaces</option>
            @foreach (var w in workspaces) { <option value="@w.Id" selected="@(wid == w.Id)">@w.Name (v@(w.Version))</option> }
        </select>
    </div>
</form>

@if (wid != null)
{
    <form asp-action="ProposeChange" method="post" class="row g-2 mb-3" style="max-width:820px">
        @Html.AntiForgeryToken()
        <input type="hidden" name="workspaceId" value="@wid" />
        <div class="col-md-5"><label class="form-label small">Relative path</label><input name="relativePath" class="form-control form-control-sm" placeholder="src/Controllers/ClaimController.cs" required /></div>
        <div class="col-md-7"><label class="form-label small">Reason</label><input name="reason" class="form-control form-control-sm" placeholder="Add claim response API" /></div>
        <div class="col-12"><label class="form-label small">New content (optional in Phase 1)</label><textarea name="newContent" rows="4" class="form-control form-control-sm mono"></textarea></div>
        <div class="col-12"><button class="btn btn-sm btn-primary">Propose change</button></div>
    </form>
}

<table class="table table-sm table-striped align-middle">
    <thead><tr><th>#</th><th>File</th><th>Reason</th><th>Model</th><th>Status</th><th>Date</th><th></th></tr></thead>
    <tbody>
    @if (!changes.Any()) { <tr><td colspan="7" class="text-muted">No changes recorded.</td></tr> }
    @foreach (var c in changes)
    {
        <tr>
            <td>@c.Id</td><td class="mono small">@c.RelativePath</td><td class="small">@c.Reason</td>
            <td class="small">@c.ModelUsed</td><td><span class="badge bg-secondary">@c.Status</span></td>
            <td class="small-muted">@c.CreatedUtc.ToString("g")</td>
            <td><a class="btn btn-sm btn-outline-secondary" asp-action="Diff" asp-route-changeId="@c.Id">Diff</a></td>
        </tr>
    }
    </tbody>
</table>
