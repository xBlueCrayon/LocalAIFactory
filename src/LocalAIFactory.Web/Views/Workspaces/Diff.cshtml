@{
    ViewData["Title"] = "Diff";
    var change = (WorkspaceChange)ViewBag.Change;
    var diff = (DiffResult)ViewBag.Diff;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Diff — <span class="mono">@change.RelativePath</span></h3>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Changes" asp-route-workspaceId="@change.WorkspaceId">Back</a>
</div>
<div class="small-muted mb-2">+@diff.Added / −@diff.Removed · @change.Status</div>

<div class="card"><div class="card-body p-0">
    <pre class="mb-0 mono" style="font-size:.82rem">@foreach (var line in diff.Lines)
{
    var cls = line.Op == DiffOp.Added ? "diff-add" : line.Op == DiffOp.Removed ? "diff-del" : "";
    var pfx = line.Op == DiffOp.Added ? "+ " : line.Op == DiffOp.Removed ? "- " : "  ";
    <div class="@cls">@pfx@line.Text</div>
}</pre>
</div></div>

@if (string.IsNullOrEmpty(change.NewContent))
{
    <div class="alert alert-secondary mt-2 small">No new content was supplied for this proposed change, so there is nothing to compare yet.</div>
}
