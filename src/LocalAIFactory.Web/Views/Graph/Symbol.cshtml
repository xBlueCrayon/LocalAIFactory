@model LocalAIFactory.Web.Controllers.GraphController.SymbolVm
@using LocalAIFactory.Web.Controllers
@{ ViewData["Title"] = Model.Symbol.Name; }

<div class="d-flex align-items-center mb-3">
    <div>
        <h4 class="mb-1"><i class="bi @GraphLabels.KindIcon(Model.Symbol.Kind) me-2"></i>@Model.Symbol.FullName</h4>
        <div class="text-muted small">
            <span class="badge text-bg-light">@GraphLabels.Kind(Model.Symbol.Kind)</span>
            @Model.Symbol.DetectedLanguage · @Model.Symbol.SourceLocusKey.Substring(0, 8)
            @if (Model.Symbol.Signature != null) { <span>· <code>@Model.Symbol.Signature</code></span> }
        </div>
    </div>
    <span class="ms-auto"></span>
    <a class="btn btn-outline-danger btn-sm" asp-action="Impact" asp-route-projectId="@Model.ProjectId" asp-route-q="@Model.Symbol.FullName"><i class="bi bi-radioactive me-1"></i>Impact analysis</a>
</div>
@await Html.PartialAsync("_ProjectNav", (Model.ProjectId, ""))
@await Html.PartialAsync("_RelationLegend")

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100"><div class="card-body">
            <h6 class="text-uppercase small text-muted mb-3"><i class="bi bi-box-arrow-in-down-left me-1"></i>Dependents — who depends on this (@Model.Dependents.Count)</h6>
            @if (!Model.Dependents.Any()) { <div class="text-muted small">Nothing depends on this symbol.</div> }
            @foreach (var d in Model.Dependents)
            {
                <div class="border-bottom py-1">
                    <div class="d-flex align-items-center">
                        <a asp-action="Symbol" asp-route-projectId="@Model.ProjectId" asp-route-id="@d.Symbol.Id" class="text-truncate text-decoration-none" style="max-width:240px" title="@d.Symbol.FullName">@d.Symbol.FullName</a>
                        <span class="ms-auto"></span>
                        <span class="badge @GraphLabels.RelationBadge(d.RelationType)" title="@d.EdgeSource">@GraphLabels.Relation(d.RelationType)</span>
                        <span class="badge text-bg-dark ms-1" title="@(d.Confidence >= 1.0 ? "deterministic" : "syntax-only string/name evidence")">@d.Confidence.ToString("0.00")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(d.Evidence))
                    {
                        <div class="small text-muted mt-1"><i class="bi bi-link-45deg me-1"></i><code class="small">@d.Evidence</code></div>
                    }
                </div>
            }
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="card h-100"><div class="card-body">
            <h6 class="text-uppercase small text-muted mb-3"><i class="bi bi-box-arrow-up-right me-1"></i>Dependencies — what this touches (@Model.Dependencies.Count)</h6>
            @if (!Model.Dependencies.Any()) { <div class="text-muted small">This symbol references nothing in the corpus.</div> }
            @foreach (var d in Model.Dependencies)
            {
                <div class="border-bottom py-1">
                    <div class="d-flex align-items-center">
                        <a asp-action="Symbol" asp-route-projectId="@Model.ProjectId" asp-route-id="@d.Symbol.Id" class="text-truncate text-decoration-none" style="max-width:240px" title="@d.Symbol.FullName">@d.Symbol.FullName</a>
                        <span class="ms-auto"></span>
                        <span class="badge @GraphLabels.RelationBadge(d.RelationType)" title="@d.EdgeSource">@GraphLabels.Relation(d.RelationType)</span>
                        <span class="badge text-bg-dark ms-1" title="@(d.Confidence >= 1.0 ? "deterministic" : "syntax-only string/name evidence")">@d.Confidence.ToString("0.00")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(d.Evidence))
                    {
                        <div class="small text-muted mt-1"><i class="bi bi-link-45deg me-1"></i><code class="small">@d.Evidence</code></div>
                    }
                </div>
            }
        </div></div>
    </div>
</div>

@{ var hasBridge = Model.Dependents.Concat(Model.Dependencies).Any(n => n.RelationType == LocalAIFactory.Core.Enums.RelationType.AccessesSql); }
@if (hasBridge)
{
    <div class="alert alert-info small mt-3 mb-0">
        <i class="bi bi-info-circle me-1"></i><strong>C#↔SQL bridge:</strong> "accesses SQL" edges are deterministic,
        syntax-only matches of a SQL object named in a string literal to a SQL symbol in this project. Confidence is
        below 1.0 by design (string evidence, not a semantic model); the snippet shown is the evidence. Dynamic SQL,
        external objects, and unresolved names are not fabricated — they simply produce no edge.
    </div>
}
