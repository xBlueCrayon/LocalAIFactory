@model List<LocalAIFactory.Core.Abstractions.SymbolHit>
@using LocalAIFactory.Web.Controllers
@{ ViewData["Title"] = "Search"; var pid = (int)ViewBag.ProjectId; }

<h4 class="mb-1"><i class="bi bi-chat-square-text me-2"></i>Retrieval Search <span class="text-muted fs-6">@ViewBag.Project</span></h4>
<div class="text-muted small mb-3">Cited answers from MSSQL — every result links to its dependents and impact.</div>
@await Html.PartialAsync("_ProjectNav", (pid, "search"))

<form asp-action="Search" method="get" class="d-flex gap-2 mb-3">
    <input type="hidden" name="projectId" value="@pid" />
    <input class="form-control form-control-lg" name="q" value="@ViewBag.Query" placeholder="Find a table, interface, service or class…" autofocus />
    <button class="btn btn-primary btn-lg"><i class="bi bi-search"></i></button>
</form>

@if (Model.Any())
{
    @foreach (var h in Model)
    {
        <div class="card mb-2"><div class="card-body py-2 d-flex align-items-center">
            <div>
                <div><i class="bi @GraphLabels.KindIcon(h.Kind) me-1"></i><strong>@h.FullName</strong>
                    <span class="badge text-bg-light ms-1">@GraphLabels.Kind(h.Kind)</span></div>
                <div class="text-muted small"><i class="bi bi-file-earmark-code me-1"></i>@h.ArtifactPath:@h.StartLine–@h.EndLine
                    · <span class="text-muted">cite: @h.Uid.ToString().Substring(0,8)</span></div>
            </div>
            <span class="ms-auto"></span>
            <a class="btn btn-outline-secondary btn-sm me-1" asp-action="Symbol" asp-route-projectId="@pid" asp-route-id="@h.Id"><i class="bi bi-diagram-2 me-1"></i>Dependents</a>
            <a class="btn btn-outline-danger btn-sm" asp-action="Impact" asp-route-projectId="@pid" asp-route-q="@h.FullName"><i class="bi bi-radioactive me-1"></i>Impact</a>
        </div></div>
    }
}
else if (!string.IsNullOrWhiteSpace((string?)ViewBag.Query))
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>No match for “@ViewBag.Query”.</div>
}
