@{ ViewData["Title"] = "Access denied"; }
<div class="text-center py-5">
    <i class="bi bi-shield-lock display-1 text-danger"></i>
    <h3 class="mt-3">Access denied</h3>
    <p class="text-muted">You don't have permission to perform this action.<br/>This attempt has been recorded in the audit trail.</p>
    <a class="btn btn-outline-secondary" asp-controller="Benchmarks" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>
