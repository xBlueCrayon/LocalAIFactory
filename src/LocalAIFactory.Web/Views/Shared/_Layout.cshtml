@inject LocalAIFactory.Core.Abstractions.ICurrentUserService Me
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(params string[] c) => c.Any(x => string.Equals(ctrl, x, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    var isAdmin = Me.IsAdmin;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · LocalAIFactory</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
<div class="app-shell">
    <aside class="sidebar">
        <div class="brand"><span class="logo"><i class="bi bi-hexagon-fill"></i></span> LocalAIFactory</div>

        <div class="nav-section">Pilot</div>
        <a class="nav-link @Active("Benchmarks")" asp-controller="Benchmarks" asp-action="Index"><span class="ico"><i class="bi bi-trophy"></i></span> Benchmarks</a>
        <a class="nav-link @Active("Graph")" asp-controller="Graph" asp-action="Index"><span class="ico"><i class="bi bi-diagram-3"></i></span> Explore Graph</a>

        @if (isAdmin)
        {
            <div class="nav-section">Administration</div>
            <a class="nav-link @Active("Users")" asp-controller="Users" asp-action="Index"><span class="ico"><i class="bi bi-people"></i></span> Users &amp; Access</a>
            <a class="nav-link @Active("Audit")" asp-controller="Audit" asp-action="Index"><span class="ico"><i class="bi bi-journal-text"></i></span> Audit Trail</a>
        }

        <div class="nav-section">Workspace</div>
        <a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index"><span class="ico"><i class="bi bi-grid-1x2"></i></span> Dashboard</a>
        <a class="nav-link @Active("Chat")" asp-controller="Chat" asp-action="Index"><span class="ico"><i class="bi bi-chat-dots"></i></span> Chat</a>
        <a class="nav-link @Active("Projects")" asp-controller="Projects" asp-action="Index"><span class="ico"><i class="bi bi-folder2"></i></span> Projects</a>

        <div class="nav-section">Knowledge</div>
        <a class="nav-link @Active("Knowledge")" asp-controller="Knowledge" asp-action="Index"><span class="ico"><i class="bi bi-journal-text"></i></span> Knowledge</a>
        <a class="nav-link @Active("BusinessRules")" asp-controller="BusinessRules" asp-action="Index"><span class="ico"><i class="bi bi-shield-check"></i></span> Business Rules</a>
        <a class="nav-link @Active("ApprovedCode")" asp-controller="ApprovedCode" asp-action="Index"><span class="ico"><i class="bi bi-code-square"></i></span> Approved Code</a>
        <a class="nav-link @Active("CodeCandidates")" asp-controller="CodeCandidates" asp-action="Index"><span class="ico"><i class="bi bi-braces-asterisk"></i></span> Code Candidates</a>
        <a class="nav-link @Active("KnowledgeGraph")" asp-controller="KnowledgeGraph" asp-action="Index"><span class="ico"><i class="bi bi-diagram-3"></i></span> Knowledge Graph</a>
        <a class="nav-link @Active("ProjectProfiles")" asp-controller="ProjectProfiles" asp-action="Index"><span class="ico"><i class="bi bi-file-earmark-text"></i></span> Project Profiles</a>

        <div class="nav-section">Pipeline</div>
        <a class="nav-link @Active("ImportWizard")" asp-controller="ImportWizard" asp-action="Index"><span class="ico"><i class="bi bi-cloud-arrow-up"></i></span> Import Project</a>
        <a class="nav-link @Active("Imports")" asp-controller="Imports" asp-action="Index"><span class="ico"><i class="bi bi-inbox"></i></span> Imports</a>
        <a class="nav-link @Active("PromptRuns")" asp-controller="PromptRuns" asp-action="Index"><span class="ico"><i class="bi bi-clock-history"></i></span> Prompt Runs</a>

        <div class="nav-section">Configuration</div>
        <a class="nav-link @Active("Models")" asp-controller="Models" asp-action="Index"><span class="ico"><i class="bi bi-cpu"></i></span> Models</a>
        <a class="nav-link @Active("TaskProfiles")" asp-controller="TaskProfiles" asp-action="Index"><span class="ico"><i class="bi bi-sliders"></i></span> Task Profiles</a>
        <a class="nav-link @Active("AgentTasks")" asp-controller="AgentTasks" asp-action="Index"><span class="ico"><i class="bi bi-list-task"></i></span> Agent Tasks</a>
        <a class="nav-link @Active("Workspaces")" asp-controller="Workspaces" asp-action="Index"><span class="ico"><i class="bi bi-layers"></i></span> Workspaces</a>
    </aside>

    <div class="app-main">
        <header class="topbar">
            <button class="sidebar-toggle" onclick="document.body.classList.toggle('sb-open')" aria-label="Menu"><i class="bi bi-list"></i></button>
            <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>
            <span class="spacer"></span>
            @if (Me.User is { } u)
            {
                <span class="crumb me-2"><i class="bi bi-person-circle me-1"></i>@u.WindowsIdentity</span>
                <span class="badge @(u.Role == LocalAIFactory.Core.Enums.UserRole.Admin ? "text-bg-danger" : u.Role == LocalAIFactory.Core.Enums.UserRole.Analyst ? "text-bg-primary" : "text-bg-secondary")">@u.Role</span>
            }
            else { <span class="crumb">Local-first AI engineering platform</span> }
        </header>

        <main class="app-content">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-1"></i>@TempData["Message"]
                    <button class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
                    <button class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
<script src="~/js/bulk-actions.js"></script>
<script>
    window.renderMarkdown = function () {
        document.querySelectorAll('[data-md]').forEach(function (el) {
            try { el.innerHTML = marked.parse(el.textContent || ''); } catch (e) { }
        });
    };
    document.addEventListener('DOMContentLoaded', window.renderMarkdown);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
