@model ApprovedCodeSnippet
@{ ViewData["Title"] = "Code detail"; }

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">@Model.Title</h3>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Back</a>
</div>
<div class="small-muted mb-2">@Model.Language @(string.IsNullOrEmpty(Model.Framework) ? "" : "· " + Model.Framework)</div>
@if (!string.IsNullOrWhiteSpace(Model.Explanation)) { <p>@Model.Explanation</p> }
<pre class="card card-body mono">@Model.Content</pre>
