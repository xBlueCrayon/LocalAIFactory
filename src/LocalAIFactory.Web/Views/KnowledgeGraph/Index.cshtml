@model List<KnowledgeEntity>
@{
    ViewData["Title"] = "Knowledge Graph";
    var projects = ViewBag.Projects as List<Project> ?? new List<Project>();
    int? projectId = ViewBag.ProjectId;
    var names = ViewBag.EntityNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var rels = ViewBag.Relationships as List<KnowledgeRelationship> ?? new List<KnowledgeRelationship>();
    string Name(int id) => names.TryGetValue(id, out var n) ? n : ("#" + id);
}

<h1 class="section-title">Knowledge graph</h1>
<p class="page-sub">Entities and relationships extracted from imported systems — SQL tables, modules, services and how they connect. Approve them to enrich retrieval.</p>

<div class="card2 mb-3">
    <div class="card2-body">
        <form method="get" class="filter-bar">
            <div>
                <label class="form-label">Project</label>
                <select name="projectId" class="form-select" onchange="this.form.submit()">
                    <option value="">All projects</option>
                    @foreach (var p in projects) { <option value="@p.Id" selected="@(projectId == p.Id)">@p.Name</option> }
                </select>
            </div>
        </form>
    </div>
</div>

<div class="card2 mb-3">
    <div class="card2-head"><h2><i class="bi bi-diagram-3 me-2"></i>Entities</h2><span class="sub">@Model.Count shown</span></div>
    <div class="card2-body">
        <form method="post" asp-action="BulkEntities" data-bulk>
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@projectId" />
            <input type="hidden" name="action" data-bulk-action />
            <div class="bulk-bar" data-bulk-bar>
                <span class="count" data-bulk-count>0 selected</span>
                <span class="sep"></span>
                <button type="button" class="btn btn-sm btn-success" data-action="approve"><i class="bi bi-check2 me-1"></i>Approve</button>
                <button type="button" class="btn btn-sm btn-warning" data-action="deprecate"><i class="bi bi-slash-circle me-1"></i>Deprecate</button>
                <button type="button" class="btn btn-sm btn-danger" data-action="delete"><i class="bi bi-trash me-1"></i>Delete</button>
                <button type="button" class="btn-clear" data-bulk-clear>Clear</button>
            </div>
            <div class="table-wrap">
                <table class="table-modern">
                    <thead><tr><th class="col-check"><input type="checkbox" data-bulk-all></th><th>Entity</th><th>Type</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    @if (!Model.Any()) { <tr><td colspan="5" class="empty">No entities. Import a project to populate the graph.</td></tr> }
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="col-check"><input type="checkbox" name="ids" value="@e.Id" data-bulk-item></td>
                            <td><strong>@e.Name</strong>@if (!string.IsNullOrWhiteSpace(e.Description)) { <div class="muted" style="max-width:480px">@e.Description</div> }</td>
                            <td><span class="badge2 slate plain">@e.EntityType</span></td>
                            <td><partial name="_StatusBadge" model="@e.Status.ToString()" /></td>
                            <td class="actions">
                                @if (e.Status != KnowledgeStatus.Approved)
                                {
                                    <button type="submit" formaction="@Url.Action("ApproveEntity")" name="id" value="@e.Id" class="btn btn-sm btn-outline-secondary">Approve</button>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </form>
    </div>
</div>

<div class="card2">
    <div class="card2-head"><h2><i class="bi bi-share me-2"></i>Relationships</h2><span class="sub">@rels.Count shown</span></div>
    <div class="card2-body">
        <form method="post" asp-action="BulkRelationships" data-bulk>
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@projectId" />
            <input type="hidden" name="action" data-bulk-action />
            <div class="bulk-bar" data-bulk-bar>
                <span class="count" data-bulk-count>0 selected</span>
                <span class="sep"></span>
                <button type="button" class="btn btn-sm btn-success" data-action="approve"><i class="bi bi-check2 me-1"></i>Approve</button>
                <button type="button" class="btn btn-sm btn-warning" data-action="deprecate"><i class="bi bi-slash-circle me-1"></i>Deprecate</button>
                <button type="button" class="btn btn-sm btn-danger" data-action="delete"><i class="bi bi-trash me-1"></i>Delete</button>
                <button type="button" class="btn-clear" data-bulk-clear>Clear</button>
            </div>
            <div class="table-wrap">
                <table class="table-modern">
                    <thead><tr><th class="col-check"><input type="checkbox" data-bulk-all></th><th>From</th><th>Relation</th><th>To</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    @if (!rels.Any()) { <tr><td colspan="6" class="empty">No relationships.</td></tr> }
                    @foreach (var r in rels)
                    {
                        <tr>
                            <td class="col-check"><input type="checkbox" name="ids" value="@r.Id" data-bulk-item></td>
                            <td>@Name(r.FromEntityId)</td>
                            <td><span class="badge2 blue plain">@r.RelationType</span></td>
                            <td>@Name(r.ToEntityId)</td>
                            <td><partial name="_StatusBadge" model="@r.Status.ToString()" /></td>
                            <td class="actions">
                                @if (r.Status != KnowledgeStatus.Approved)
                                {
                                    <button type="submit" formaction="@Url.Action("ApproveRelationship")" name="id" value="@r.Id" class="btn btn-sm btn-outline-secondary">Approve</button>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </form>
    </div>
</div>
